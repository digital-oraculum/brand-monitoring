# Google OAuth – utwórz w Google Cloud Console (typ: Aplikacja internetowa)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:3300/auth/callback
# Produkcja (Vercel): https://TWOJA-DOMENA.vercel.app/auth/callback

PORT=3300
HOST=127.0.0.1
DATA_PATH=./data/tokens.json
# Vercel: wklej zawartość data/tokens.json po pierwszym logowaniu lokalnie
# TOKENS_JSON={"accessToken":"...","refreshToken":"...","expiryDate":...}

# Domeny raportu WSKZ (po przecinku)
WSKZ_DOMAINS=wskz.pl,studia-online.pl,studia-pedagogiczne.pl,studia-wroclaw.pl
