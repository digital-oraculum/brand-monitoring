# Google OAuth – utwórz w Google Cloud Console (typ: Aplikacja internetowa)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:3300/auth/callback
# Produkcja (Vercel): https://TWOJA-DOMENA.vercel.app/auth/callback

# Sekret do podpisywania sesji użytkowników (losowy ciąg, min. 32 znaki)
SESSION_SECRET=

# Opcjonalnie: lista dozwolonych e-maili (po przecinku). Puste = każdy z Google.
# ALLOWED_EMAILS=marcin.halas@wskz.pl,kolega@wskz.pl

PORT=3300
HOST=127.0.0.1
DATA_PATH=./data/tokens.json

# Token GSC po stronie serwera (konto z dostępem do domen WSKZ).
# Lokalnie: plik data/tokens.json po jednorazowym OAuth z scope webmasters.readonly.
# Vercel: wklej JSON jako GSC_TOKENS_JSON lub TOKENS_JSON
# GSC_TOKENS_JSON={"accessToken":"...","refreshToken":"...","expiryDate":...}

# Domeny raportu WSKZ (po przecinku)
WSKZ_DOMAINS=wskz.pl,studia-online.pl,studia-pedagogiczne.pl,studia-wroclaw.pl
